# Token bot dari @BotFather di Telegram
TELEGRAM_TOKEN=isi_token_bot_anda

# API key gratis dari https://console.groq.com (untuk AI deteksi & baca struk)
GROQ_API_KEY=isi_groq_api_key

# ID Google Sheet (ambil dari URL: docs.google.com/spreadsheets/d/<INI_ID-nya>/edit)
SHEET_ID=isi_sheet_id

# Nama tab/worksheet (opsional, default: Transaksi)
SHEET_NAME=Transaksi

# Path file kredensial service account (default: credentials.json)
SERVICE_ACCOUNT_FILE=credentials.json

# Mode jalan: polling (lokal/VPS) atau webhook (hosting Render)
RUN_MODE=polling

# Hanya untuk mode webhook & jika BUKAN di Render.
# Di Render, biarkan kosong (otomatis pakai RENDER_EXTERNAL_URL).
# WEBHOOK_URL=https://namabot-anda.onrender.com
